# Comma-separated list of allowed request origins
VALID_ORIGINS=https://yoursite.com,https://www.yoursite.com

# Gmail account that sends the email
GMAIL_USER=you@gmail.com

# Gmail App Password (not your account password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Address that receives submitted contact forms
MAIL_TO=inbox@yoursite.com
